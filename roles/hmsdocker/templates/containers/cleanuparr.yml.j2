{% from 'macros/proxy_labels.j2' import proxy_labels with context %}
services:
  cleanuparr:
    image: ghcr.io/cleanuparr/cleanuparr:latest
    container_name: cleanuparr
    restart: ${RESTART_POLICY}
    security_opt:
      - no-new-privileges:true
    {% if 'cleanuparr' in expose_ports_enabled_containers %}
    ports:
      - "11011:11011"
    {% endif %}
    networks:
      - proxy_net
      - download_net
    volumes:
      - ${HMSD_APPS_PATH}/cleanuparr/config:/config
    environment:
      - PORT=11011
      - BASE_PATH=
      - PUID=${PUID}
      - PGID=${PGID}
      - UMASK=022
      - TZ=${TIMEZONE}
    {% if 'cleanuparr' in traefik_enabled_containers %}
    labels:
{{ proxy_labels(name='cleanuparr', port=11011) -}}
    {% endif %}
    # Health check configuration
    healthcheck:
      test: ["CMD", "curl", "-f", "http://127.0.0.1:11011/health"]
      interval: 30s        # Check every 30 seconds
      timeout: 10s         # Allow up to 10 seconds for response
      start_period: 30s    # Wait 30 seconds before first check
      retries: 3           # Mark unhealthy after 3 consecutive failures
