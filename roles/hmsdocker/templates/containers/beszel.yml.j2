{% from 'macros/proxy_labels.j2' import proxy_labels with context %}
services:
  beszel:
    image: henrygd/beszel:latest
    container_name: beszel
    restart: ${RESTART_POLICY}
    security_opt:
      - no-new-privileges:true
    logging:
      options:
        max-size: "12m"
        max-file: "5"
      driver: json-file
    networks:
      - proxy_net
    environment:
      APP_URL: http{{ 's' if hmsdocker_proxy_ssl_enabled }}://{{ hms_docker_container_map['beszel']['proxy_host_rule'] | default('beszel') }}.${HMSD_DOMAIN}{{ ':8091' if 'beszel' in expose_ports_enabled_containers }}
      HEARTBEAT_URL: ${BESZEL_HEARTBEAT_URL:-}
    {% if 'beszel' in expose_ports_enabled_containers %}
    ports:
      - 8091:8090
    {% endif %}
    volumes:
      - ${HMSD_APPS_PATH}/beszel/config/beszel_data:/beszel_data
      - ${HMSD_APPS_PATH}/beszel/config/beszel_socket:/beszel_socket
    {% if 'beszel' in traefik_enabled_containers or 'beszel' in homepage_enabled_containers %}
    labels:
{{ proxy_labels(name='beszel', port=8090) -}}
      {% if 'beszel' in homepage_enabled_containers %}
      - homepage.group=Infrastructure
      - homepage.name=beszel
      - homepage.icon=beszel.png
      - homepage.href=http://{{ hms_docker_container_map['beszel']['proxy_host_rule'] | default('beszel') }}.${HMSD_DOMAIN}
      - homepage.description=Monitoring
      - homepage.widget.type=beszel
      - homepage.widget.url=http://beszel:8090
      - homepage.widget.username=${BESZEL_EMAIL:-}
      - homepage.widget.password=${BESZEL_PASSWORD:-}
      - homepage.widget.version=2
        {% if 'beszel' in homepage_stats_enabled_containers %}
      - homepage.showStats=true
        {% endif %}
      {% endif %}
    {% endif %}
    # Image is distroless — no shell, curl, or wget. The beszel binary ships
    # a built-in `health` subcommand that hits the hub's /api/health endpoint.
    healthcheck:
      test: ["CMD", "/beszel", "health", "--url", "http://127.0.0.1:8090"]
      interval: 5s
      timeout: 2s
      retries: 3
      start_period: 30s

  beszel-agent:
    image: henrygd/beszel-agent:alpine
    container_name: beszel-agent
    restart: ${RESTART_POLICY}
    security_opt:
      - no-new-privileges:true
    logging:
      options:
        max-size: "12m"
        max-file: "5"
      driver: json-file
    network_mode: host
    volumes:
      - ${HMSD_APPS_PATH}/beszel/config/beszel_agent_data:/var/lib/beszel-agent
      - ${HMSD_APPS_PATH}/beszel/config/beszel_socket:/beszel_socket
      - /var/run/docker.sock:/var/run/docker.sock:ro
    environment:
      LISTEN: /beszel_socket/beszel.sock
      HUB_URL: http{{ 's' if hmsdocker_proxy_ssl_enabled }}://{{ hms_docker_container_map['beszel']['proxy_host_rule'] | default('beszel') }}.${HMSD_DOMAIN}{{ ':8091' if 'beszel' in expose_ports_enabled_containers }}
      TOKEN: ${BESZEL_TOKEN:-}
      KEY: ${BESZEL_KEY:-}
    devices:
    {% for device in hmsdocker_monitor_disk_devices %}
      - {{ device }}
    {% endfor %}
    cap_add:
      - SYS_RAWIO # required for S.M.A.R.T. data
      - SYS_ADMIN # required for NVMe S.M.A.R.T. data
