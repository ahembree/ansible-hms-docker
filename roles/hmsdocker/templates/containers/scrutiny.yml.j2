{% from 'macros/proxy_labels.j2' import proxy_labels with context %}
services:
  scrutiny:
    image: ghcr.io/analogj/scrutiny:latest-omnibus
    container_name: scrutiny
    logging:
      options:
        max-size: "12m"
        max-file: "5"
      driver: json-file
    networks:
      - proxy_net
    cap_add:
      - SYS_RAWIO
      - SYS_ADMIN #required for NVMe drives
    volumes:
      - ${HMSD_APPS_PATH}/scrutiny/config/config:/opt/scrutiny/config
      - ${HMSD_APPS_PATH}/scrutiny/config/influxdb:/opt/scrutiny/influxdb
      - /run/udev:/run/udev:ro
    {% if 'scrutiny' in expose_ports_enabled_containers %}
    ports:
      - 8087:8080
    {% endif %}
    devices:
    {% for device in hmsdocker_monitor_disk_devices %}
      - {{ device }}
    {% endfor %}
    restart: ${RESTART_POLICY}
    security_opt:
      - no-new-privileges:true
    {% if 'scrutiny' in traefik_enabled_containers or 'scrutiny' in homepage_enabled_containers %}
    labels:
{{ proxy_labels(name='scrutiny', port=8080) -}}
      {% if 'scrutiny' in homepage_enabled_containers %}
      - homepage.group=Infrastructure
      - homepage.name=Scrutiny
      - homepage.icon=scrutiny.png
      - homepage.href=http://{{ hms_docker_container_map['scrutiny']['proxy_host_rule'] | default('scrutiny') }}.${HMSD_DOMAIN}
      - homepage.description=Disk Health
      - homepage.widget.type=scrutiny
      - homepage.widget.url=http://scrutiny:8080
        {% if 'scrutiny' in homepage_stats_enabled_containers %}
      - homepage.showStats=true
        {% endif %}
      {% endif %}
    {% endif %}
    healthcheck:
      test: curl -f http://127.0.0.1:8080/ || exit 1
      interval: 5s
      timeout: 2s
      retries: 3
      start_period: 60s
