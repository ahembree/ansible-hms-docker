{% from 'macros/proxy_labels.j2' import proxy_labels with context %}
services:
  emby:
    image: lscr.io/linuxserver/emby:latest
    container_name: emby
    restart: ${RESTART_POLICY}
    security_opt:
      - no-new-privileges:true
    logging:
      options:
        max-size: "12m"
        max-file: "5"
      driver: json-file
    networks:
      - proxy_net
    {% if enable_intel_gpu %}
    devices:
      - /dev/dri:/dev/dri
    {% endif %}
    environment:
      - PUID=${PUID}
      - PGID=${PGID}
      - TZ=${TIMEZONE}
    {% if enable_nvidia_gpu %}
      - NVIDIA_VISIBLE_DEVICES=all
    runtime: nvidia
    {% endif %}
    volumes:
      - ${HMSD_APPS_PATH}/emby/config:/config
      {% if not hmsdocker_transcode_tmpfs_enabled | default(false) %}
      - {{ plex_transcode_folder }}/cache:/cache
      {% endif %}
      # media folder where all movies and series are stored
      - ${HMSD_MOUNT_PATH}:/data
    {% if hmsdocker_transcode_tmpfs_enabled | default(false) %}
    tmpfs:
      - /cache:size={{ hmsdocker_transcode_tmpfs_size | default('4g') }},mode=1777
    {% endif %}
    {% if 'emby' in expose_ports_enabled_containers %}
    ports:
      {% if 'jellyfin' in expose_ports_enabled_containers %}
      - 8097:8096
      - 8921:8920 #optional
      {% else %}
      - 8096:8096
      - 8920:8920 #optional
      {% endif %}
    {% endif %}
    {% if 'emby' in traefik_enabled_containers or 'emby' in homepage_enabled_containers %}
    labels:
{{ proxy_labels(name='emby', port=8096) -}}
      {% if 'emby' in homepage_enabled_containers %}
      - homepage.group=Media
      - homepage.name=Emby
      - homepage.icon=emby.png
      - homepage.href=http://{{ hms_docker_container_map['emby']['proxy_host_rule'] | default('emby') }}.${HMSD_DOMAIN}
      - homepage.description=Media Server
      - homepage.widget.type=emby
      - homepage.widget.url=https://emby:8096
      - homepage.widget.key=${EMBY_KEY:-apikeyapikeyapikey}
        {% if 'emby' in homepage_stats_enabled_containers %}
      - homepage.showStats=true
        {% endif %}
      {% endif %}
    {% endif %}
    healthcheck:
      test: curl -f http://127.0.0.1:8096/System/Ping || exit 1
      interval: 5s
      timeout: 2s
      retries: 3
      start_period: 60s
