{% from 'macros/proxy_labels.j2' import proxy_labels with context %}
services:
  homepage:
    image: ghcr.io/gethomepage/homepage:latest
    container_name: homepage
    restart: ${RESTART_POLICY}
    security_opt:
      - no-new-privileges:true
    logging:
      options:
        max-size: "12m"
        max-file: "5"
      driver: json-file
    networks:
      - proxy_net
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - ${HMSD_APPS_PATH}/homepage/config:/app/config
    environment:
      - TZ=${TIMEZONE}
      - HOMEPAGE_ALLOWED_HOSTS={{ hms_docker_container_map['homepage']['proxy_host_rule'] | default('homepage') }}.${HMSD_DOMAIN},{{ ansible_facts.default_ipv4.address }}:3000
    {% if 'homepage' in expose_ports_enabled_containers %}
    ports:
      - 3000:3000
    {% endif %}
    {% if 'homepage' in proxy_enabled_containers %}
    labels:
{{ proxy_labels(name='homepage', port=3000) -}}
    {% endif %}
    healthcheck:
      test: wget --spider -q http://127.0.0.1:3000/ || exit 1
      interval: 5s
      timeout: 2s
      retries: 3
      start_period: 30s
