{% from 'macros/proxy_labels.j2' import proxy_labels with context %}
services:
  librariarr:
    image: ahembree/librariarr:latest
    container_name: librariarr
    restart: ${RESTART_POLICY}
    security_opt:
      - no-new-privileges:true
    networks:
      - proxy_net
      - librariarr_net
    logging:
      options:
        max-size: "12m"
        max-file: "5"
      driver: json-file
    {% if 'librariarr' in expose_ports_enabled_containers %}
    ports:
      - 3100:3000
    {% endif %}
    volumes:
      - ${HMSD_APPS_PATH}/librariarr/config/app:/config
      - ${HMSD_MOUNT_PATH}:/data:ro
    environment:
      - DATABASE_URL=postgresql://librariarr:librariarr@librariarr-db:5432/librariarr
      - TZ=${TIMEZONE}
      - PUID=${PUID}
      - PGID=${PGID}
    depends_on:
      librariarr-db:
        condition: service_healthy
    {% if 'librariarr' in traefik_enabled_containers or 'librariarr' in homepage_enabled_containers %}
    labels:
{{ proxy_labels(name='librariarr', port=3000) -}}
      {% if 'librariarr' in homepage_enabled_containers %}
      - homepage.group=Managers
      - homepage.name=Librariarr
      - homepage.icon=librariarr.png
      - homepage.href=http://{{ hms_docker_container_map['librariarr']['proxy_host_rule'] | default('librariarr') }}.${HMSD_DOMAIN}
      - homepage.description=Media Library Manager
        {% if 'librariarr' in homepage_stats_enabled_containers %}
      - homepage.showStats=true
        {% endif %}
      {% endif %}
    {% endif %}
    healthcheck:
      test: curl -f http://127.0.0.1:3000/ || exit 1
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 30s

  librariarr-db:
    image: postgres:18-alpine
    container_name: librariarr-db
    restart: ${RESTART_POLICY}
    security_opt:
      - no-new-privileges:true
    user: ${PUID}:${PGID}
    networks:
      - proxy_net
      - librariarr_net
    logging:
      options:
        max-size: "12m"
        max-file: "5"
      driver: json-file
    environment:
      - POSTGRES_USER=librariarr
      - POSTGRES_PASSWORD=${LIBRARIARR_DB_PASS:-librariarr}
      - POSTGRES_DB=librariarr
    volumes:
      - librariarr-db:/var/lib/postgresql
    healthcheck:
      test: pg_isready -U librariarr -d librariarr
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 20s

volumes:
  librariarr-db:

networks:
  librariarr_net:
    driver: bridge
    attachable: false
