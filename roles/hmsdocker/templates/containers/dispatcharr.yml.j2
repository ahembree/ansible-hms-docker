{% from 'macros/proxy_labels.j2' import proxy_labels with context %}
services:
  dispatcharr:
    image: ghcr.io/dispatcharr/dispatcharr:latest
    container_name: dispatcharr
    restart: ${RESTART_POLICY}
    security_opt:
      - no-new-privileges:true
    logging:
      options:
        max-size: "12m"
        max-file: "5"
      driver: json-file
    networks:
      - proxy_net
    {% if 'dispatcharr' in expose_ports_enabled_containers %}
    ports:
      - 9191:9191
    {% endif %}
    {% if enable_intel_gpu %}
    devices:
      - "/dev/dri:/dev/dri"
    {% endif %}
    volumes:
      - ${HMSD_APPS_PATH}/dispatcharr/config:/data
      - ${HMSD_MOUNT_PATH}:/library
    environment:
      - TZ=${TIMEZONE}
      - PUID=${PUID}
      - PGID=${PGID}
      - DISPATCHARR_ENV=aio
      - REDIS_HOST=localhost
      - CELERY_BROKER_URL=redis://127.0.0.1:6379/0
      - DISPATCHARR_LOG_LEVEL=info
    {% if enable_nvidia_gpu %}
      - NVIDIA_DRIVER_CAPABILITIES=compute,video,utility
      - NVIDIA_VISIBLE_DEVICES=all
    runtime: nvidia
    {% endif %}
    {% if 'dispatcharr' in traefik_enabled_containers %}
    labels:
{{ proxy_labels(name='dispatcharr', port=9191) -}}
    {% endif %}
    healthcheck:
      test: curl -f http://127.0.0.1:9191 || exit 1
      interval: 5s
      timeout: 2s
      retries: 3
      start_period: 20s
