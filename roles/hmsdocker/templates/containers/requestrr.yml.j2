{% from 'macros/proxy_labels.j2' import proxy_labels with context %}
services:
  requestrr:
    image: thomst08/requestrr:latest
    container_name: requestrr
    restart: ${RESTART_POLICY}
    security_opt:
      - no-new-privileges:true
    logging:
      options:
        max-size: "12m"
        max-file: "5"
      driver: json-file
    networks:
      - proxy_net
    environment:
      - PUID=${PUID}
      - PGID=${PGID}
      - TZ=${TIMEZONE}
    volumes:
      - ${HMSD_APPS_PATH}/requestrr/config:/root/config
    {% if 'requestrr' in expose_ports_enabled_containers %}
    ports:
      - 4545:4545
    {% endif %}
    {% if 'requestrr' in proxy_enabled_containers %}
    labels:
{{ proxy_labels(name='requestrr', port=4545) -}}
    {% endif %}
    # Image has bash but no curl/wget/nc; /dev/tcp is a bash builtin and the
    # default healthcheck shell is dash, so bash must be invoked explicitly.
    healthcheck:
      test: ["CMD", "bash", "-c", "echo > /dev/tcp/127.0.0.1/4545"]
      interval: 5s
      timeout: 2s
      retries: 3
      start_period: 30s
