{% from 'macros/proxy_labels.j2' import proxy_labels with context %}
services:
  speedtest-tracker:
    image: lscr.io/linuxserver/speedtest-tracker:latest
    container_name: speedtest-tracker
    restart: ${RESTART_POLICY}
    security_opt:
      - no-new-privileges:true
    logging:
      options:
        max-size: "12m"
        max-file: "5"
      driver: json-file
    networks:
      - proxy_net
  {% if 'speedtest-tracker' in expose_ports_enabled_containers %}
    ports:
      - 8090:80
      - 8444:443
  {% endif %}
    environment:
      - PUID=${PUID}
      - PGID=${PGID}
      - APP_KEY=${SPEEDTEST_API_KEY}
      - APP_URL=http://{{ hms_docker_container_map['speedtest-tracker']['proxy_host_rule'] | default('speedtest') }}.${HMSD_DOMAIN}
      - DB_CONNECTION=sqlite
      - SPEEDTEST_SCHEDULE=${SPEEDTEST_SCHEDULE}
      - APP_TIMEZONE=${TIMEZONE}
      - DISPLAY_TIMEZONE=${TIMEZONE}
    volumes:
      - ${HMSD_APPS_PATH}/speedtest-tracker/config:/config
    {% if 'speedtest-tracker' in traefik_enabled_containers or 'speedtest-tracker' in homepage_enabled_containers %}
    labels:
{{ proxy_labels(name='speedtest-tracker', port=80, label_name='speedtest') -}}
      {% if 'speedtest-tracker' in homepage_enabled_containers %}
      - homepage.group=Infrastructure
      - homepage.name=Speedtest Tracker
      - homepage.icon=speedtest-tracker.png
      - homepage.href=http://{{ hms_docker_container_map['speedtest-tracker']['proxy_host_rule'] | default('speedtest') }}.${HMSD_DOMAIN}
      - homepage.description=Speedtest Tracker
      - homepage.widget.type=speedtest
      - homepage.widget.url=http://speedtest-tracker
      - homepage.widget.version=2
      - homepage.widget.key=${HOMEPAGE_SPEEDTEST_API_KEY}
      - homepage.widget.bitratePrecision=1
      {% endif %}
    {% endif %}
    healthcheck:
      test: curl -f http://127.0.0.1:80/ || exit 1
      interval: 5s
      timeout: 2s
      retries: 3
      start_period: 30s
