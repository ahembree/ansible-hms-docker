{% from 'macros/proxy_labels.j2' import proxy_labels with context %}
services:
  calibre:
    image: lscr.io/linuxserver/calibre:latest
    container_name: calibre
    restart: ${RESTART_POLICY}
    security_opt:
      - no-new-privileges:true
    logging:
      options:
        max-size: "12m"
        max-file: "5"
      driver: json-file
    networks:
      - proxy_net
    environment:
      - PUID=${PUID}
      - PGID=${PGID}
      - TZ=${TIMEZONE}
    volumes:
      - ${HMSD_APPS_PATH}/calibre/config:/config
      - ${HMSD_MOUNT_PATH}:/data
    {% if 'calibre' in expose_ports_enabled_containers %}
    ports:
      - 8083:8080 # remote desktop http
      - 8182:8181 # remote desktop https
      - 8084:8081 # webserver (must be enabled in settings using remote desktop)
    {% endif %}
    {% if 'calibre' in traefik_enabled_containers %}
    labels:
{{ proxy_labels(name='calibre', port=8181, scheme='https') -}}
    {% endif %}
    healthcheck:
      test: curl -fk https://127.0.0.1:8181/ || exit 1
      interval: 5s
      timeout: 2s
      retries: 3
      start_period: 60s
