{% from 'macros/proxy_labels.j2' import proxy_labels with context %}
services:
  pasta:
    image: cglatot/pasta:latest
    container_name: pasta
    restart: ${RESTART_POLICY}
    security_opt:
      - no-new-privileges:true
    logging:
      options:
        max-size: "12m"
        max-file: "5"
      driver: json-file
    networks:
      - proxy_net
    {% if 'pasta' in expose_ports_enabled_containers %}
    ports:
      - 8085:80
    {% endif %}
    {% if 'pasta' in traefik_enabled_containers %}
    labels:
{{ proxy_labels(name='pasta', port=80) -}}
    {% endif %}
    # Image has bash but no curl/wget/nc; /dev/tcp is a bash builtin and the
    # default healthcheck shell is dash, so bash must be invoked explicitly.
    healthcheck:
      test: ["CMD", "bash", "-c", "echo > /dev/tcp/127.0.0.1/80"]
      interval: 5s
      timeout: 2s
      retries: 3
      start_period: 30s
