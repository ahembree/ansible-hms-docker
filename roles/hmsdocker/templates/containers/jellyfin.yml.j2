{% from 'macros/proxy_labels.j2' import proxy_labels with context %}
services:
  jellyfin:
    image: lscr.io/linuxserver/jellyfin:latest
    container_name: jellyfin
    restart: ${RESTART_POLICY}
    security_opt:
      - no-new-privileges:true
    logging:
      options:
        max-size: "12m"
        max-file: "5"
      driver: json-file
    networks:
      - proxy_net
    {% if enable_intel_gpu %}
    devices:
      - /dev/dri:/dev/dri
    {% endif %}
    {% if 'jellyfin' in expose_ports_enabled_containers %}
    ports:
      - 8096:8096
      - 8920:8920 #optional
      - 7359:7359/udp #optional
    {% endif %}
    volumes:
      - ${HMSD_APPS_PATH}/jellyfin/config:/config
      {% if not hmsdocker_transcode_tmpfs_enabled | default(false) %}
      - {{ plex_transcode_folder }}/cache:/cache
      {% endif %}
      # media folder where all movies and series are stored
      - ${HMSD_MOUNT_PATH}:/data
    {% if hmsdocker_transcode_tmpfs_enabled | default(false) %}
    tmpfs:
      - /cache:size={{ hmsdocker_transcode_tmpfs_size | default('4g') }},mode=1777
    {% endif %}
    environment:
      - TZ=${TIMEZONE}
      - PUID=${PUID}
      - PGID=${PGID}
    {% if enable_nvidia_gpu %}
      - NVIDIA_VISIBLE_DEVICES=all
    runtime: nvidia
    {% endif %}
    {% if 'jellyfin' in traefik_enabled_containers or 'jellyfin' in homepage_enabled_containers %}
    labels:
{{ proxy_labels(name='jellyfin', port=8096) -}}
      {% if 'jellyfin' in homepage_enabled_containers %}
      - homepage.group=Media
      - homepage.name=Jellyfin
      - homepage.icon=jellyfin.png
      - homepage.href=http://{{ hms_docker_container_map['jellyfin']['proxy_host_rule'] | default('jellyfin') }}.${HMSD_DOMAIN}
      - homepage.description=Media Server
      - homepage.widget.type=jellyfin
      - homepage.widget.url=https://jellyfin:8096
      - homepage.widget.key=${JELLYFIN_KEY:-apikeyapikeyapikey}
        {% if 'jellyfin' in homepage_stats_enabled_containers %}
      - homepage.showStats=true
        {% endif %}
      {% endif %}
    {% endif %}
    healthcheck:
      test: curl -f http://127.0.0.1:8096/health || exit 1
      interval: 5s
      timeout: 2s
      retries: 3
      start_period: 60s
