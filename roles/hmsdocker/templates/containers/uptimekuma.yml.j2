{% from 'macros/proxy_labels.j2' import proxy_labels with context %}
services:
  uptime-kuma:
    image: louislam/uptime-kuma:2
    container_name: uptime-kuma
    restart: ${RESTART_POLICY}
    security_opt:
      - no-new-privileges:true
    logging:
      options:
        max-size: "12m"
        max-file: "5"
      driver: json-file
    networks:
      - proxy_net
    volumes:
      - ${HMSD_APPS_PATH}/uptimekuma/config:/app/data
      - /var/run/docker.sock:/var/run/docker.sock
    {% if 'uptimekuma' in expose_ports_enabled_containers %}
    ports:
      - 3001:3001
    {% endif %}
    environment:
      - PUID=${PUID}
      - PGID=${PGID}
      - TZ=${TIMEZONE}
    {% if 'uptimekuma' in proxy_enabled_containers or 'uptimekuma' in homepage_enabled_containers %}
    labels:
{{ proxy_labels(name='uptimekuma', port=3001) -}}
      {% if 'uptimekuma' in homepage_enabled_containers %}
      - homepage.group=Media
      - homepage.name=Uptime Kuma
      - homepage.icon=uptime-kuma.png
      - homepage.href=https://{{ hms_docker_container_map['uptimekuma']['proxy_host_rule'] | default('uptimekuma') }}.${HMSD_DOMAIN}
      - homepage.description=Infrastructure Monitoring
      - homepage.widget.type=uptimekuma
      - homepage.widget.url=https://{{ hms_docker_container_map['uptimekuma']['proxy_host_rule'] | default('uptimekuma') }}.${HMSD_DOMAIN}
      - homepage.widget.slug=${HOMEPAGE_UPTIMEKUMA_SLUG}
        {% if 'uptimekuma' in homepage_stats_enabled_containers %}
      - homepage.showStats=true
        {% endif %}
      {% endif %}
    {% endif %}
    # Image ships an upstream-recommended healthcheck binary at /app/extra/healthcheck.
    healthcheck:
      test: ["CMD", "/app/extra/healthcheck"]
      interval: 5s
      timeout: 2s
      retries: 3
      start_period: 30s
