{
    {% if hmsdocker_proxy_ssl_letsencrypt_email | length > 0 %}
    email {{ hmsdocker_proxy_ssl_letsencrypt_email }}
    {% endif %}
    {% if hmsdocker_proxy_ssl_enabled and hmsdocker_proxy_ssl_use_staging %}
    acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
    {% endif %}
    {% if not hmsdocker_proxy_ssl_enabled %}
    # SSL disabled — issue self-signed certs locally so HTTPS still works
    # on the LAN without depending on an external CA.
    local_certs
    {% endif %}
    {% if caddy_ssl_dns_provider_directive | length > 0 %}
    acme_dns {{ caddy_ssl_dns_provider_directive }}
    {% endif %}
    log {
        level {{ hmsdocker_proxy_log_level }}
    }
    {% if hmsdocker_proxy_enable_access_logs %}
    log access {
        output stdout
        format json
    }
    {% endif %}
}

# Snippet: deny access to anyone outside the allowlist. The protected
# upstream URL is passed as args[0] by the importer. Service templates
# emit "caddy.import=internal_only <upstream>" as a Docker label.

(internal_only) {
    @internal remote_ip {% for cidr in hmsdocker_proxy_subnet_allow_list | regex_replace(', ', ',') | split(',') %}{{ cidr.strip() }} {% endfor %}127.0.0.1/32
    handle @internal {
        reverse_proxy {args[0]}
    }
    respond 403
}

# Same as internal_only but reverse-proxies over HTTPS to an upstream
# with a self-signed cert (Plex, Heimdall, Authentik, Calibre, etc.).
# Mirrors Traefik's serversTransport.insecureSkipVerify default.
(internal_only_https) {
    @internal remote_ip {% for cidr in hmsdocker_proxy_subnet_allow_list | regex_replace(', ', ',') | split(',') %}{{ cidr.strip() }} {% endfor %}127.0.0.1/32
    handle @internal {
        reverse_proxy {args[0]} {
            transport http {
                tls
                tls_insecure_skip_verify
            }
        }
    }
    respond 403
}

# Snippet: expose to the public internet (no allowlist).
(external) {
    reverse_proxy {args[0]}
}

(external_https) {
    reverse_proxy {args[0]} {
        transport http {
            tls
            tls_insecure_skip_verify
        }
    }
}

# Snippet: gate the site behind an Authentik proxy outpost. The outpost
# container name (without the :9000 suffix) is passed as args[0]. Used
# by services whose container_map entry has `authentik: true` once
# authentik is enabled and SSL is on.

(authentik_proxy) {
    forward_auth {args[0]}:9000 {
        uri /outpost.goauthentik.io/auth/caddy
        copy_headers X-authentik-username X-authentik-groups X-authentik-email X-authentik-name X-authentik-uid X-authentik-jwt X-authentik-meta-jwks X-authentik-meta-outpost X-authentik-meta-provider X-authentik-meta-app X-authentik-meta-version
        trusted_proxies private_ranges
    }
    handle_path /outpost.goauthentik.io/* {
        reverse_proxy {args[0]}:9000
    }
}

# Pull in per-ext-host fragments rendered for hmsdocker_proxy_ext_hosts_list.
# Glob fails open if no fragments are present.
import /etc/caddy/conf.d/*.caddy
