#######################################################################
# Global options
#######################################################################
{
    {% if hmsdocker_proxy_ssl_letsencrypt_email | length > 0 %}
    email {{ hmsdocker_proxy_ssl_letsencrypt_email }}
    {% endif %}
    {% if hmsdocker_proxy_ssl_enabled %}
    {# Suppress automatic cert issuance for individual hostnames in
       per-service site blocks. The wildcard site block below issues
       one cert (with every entry of hmsdocker_proxy_ssl_sans on it)
       and per-service sites serve that cert from Caddy's cert pool. #}
    auto_https disable_certs

    {% if hmsdocker_proxy_ssl_use_staging %}
    acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
    {% endif %}
    {% else %}
    {# SSL disabled — local self-signed certs so HTTPS still works on the LAN. #}
    local_certs
    {% endif %}
    log {
        level {{ hmsdocker_proxy_log_level }}
    }
    {% if hmsdocker_proxy_enable_access_logs %}
    log access {
        output stdout
        format json
    }
    {% endif %}
}


#######################################################################
# Wildcard certificate
#######################################################################
{% if hmsdocker_proxy_ssl_enabled %}
{# A single site block with every SAN as a hostname. Caddy issues one
   cert with all of those as Subject Alternative Names. Per-service
   site blocks (loaded from conf.d below) match more-specific
   hostnames and Caddy serves them this same cert from its pool. #}
{% for san in hmsdocker_proxy_ssl_sans %}{{ san }}{% if not loop.last %}, {% endif %}{% endfor %} {
    tls {
        dns {{ caddy_ssl_dns_provider_directive }}{% if caddy_ssl_dns_provider_args | length > 0 %} {{ caddy_ssl_dns_provider_args }}{% endif +%}
        resolvers {{ hmsdocker_proxy_ssl_dns_resolver_1 }} {{ hmsdocker_proxy_ssl_dns_resolver_2 }}
    }
    {# No routing: an unmatched subdomain returns 404 here instead of
       leaking the upstream. Per-service blocks below take priority for
       known hostnames. #}
    respond 404
}
{% endif %}


#######################################################################
# Snippets imported by per-service fragments
#######################################################################

# Snippet: deny access to anyone outside the allowlist. The protected
# upstream URL is passed as args[0] by the importer. Service fragments
# emit "import internal_only <upstream>".

(internal_only) {
    @internal remote_ip {% for cidr in hmsdocker_proxy_subnet_allow_list | regex_replace(', ', ',') | split(',') %}{{ cidr.strip() }} {% endfor %}127.0.0.1/32
    handle @internal {
        reverse_proxy {args[0]}
    }
    respond 403
}

# Same as internal_only but reverse-proxies over HTTPS to an upstream
# with a self-signed cert (Plex, Heimdall, Authentik, Calibre, etc.).
# Mirrors Traefik's serversTransport.insecureSkipVerify default.
(internal_only_https) {
    @internal remote_ip {% for cidr in hmsdocker_proxy_subnet_allow_list | regex_replace(', ', ',') | split(',') %}{{ cidr.strip() }} {% endfor %}127.0.0.1/32
    handle @internal {
        reverse_proxy {args[0]} {
            transport http {
                tls
                tls_insecure_skip_verify
            }
        }
    }
    respond 403
}

# Snippet: expose to the public internet (no allowlist).
(external) {
    reverse_proxy {args[0]}
}

(external_https) {
    reverse_proxy {args[0]} {
        transport http {
            tls
            tls_insecure_skip_verify
        }
    }
}

# Snippet: gate the site behind an Authentik proxy outpost. The outpost
# container name (without the :9000 suffix) is passed as args[0]. Used
# by services whose container_map entry has `authentik: true` once
# authentik is enabled and SSL is on.

(authentik_proxy) {
    forward_auth {args[0]}:9000 {
        uri /outpost.goauthentik.io/auth/caddy
        copy_headers X-authentik-username X-authentik-groups X-authentik-email X-authentik-name X-authentik-uid X-authentik-jwt X-authentik-meta-jwks X-authentik-meta-outpost X-authentik-meta-provider X-authentik-meta-app X-authentik-meta-version
        trusted_proxies private_ranges
    }
    handle_path /outpost.goauthentik.io/* {
        reverse_proxy {args[0]}:9000
    }
}


#######################################################################
# Per-service site blocks
#######################################################################

import /etc/caddy/conf.d/*.caddy
